{
  "name": "corporate-ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit && npm run build:lib && npm run build:demo",
    "build:lib": "vite build --mode library",
    "build:demo": "vite build && node scripts/inline-demo-css.mjs",
    "preview": "vite preview --outDir dist/demo --host 127.0.0.1",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests .storybook vite.config.ts vitest.config.ts eslint.config.js",
    "format": "prettier . --write"
  },
  "exports": {
    ".": {
      "types": "./dist/library/index.d.ts",
      "import": "./dist/library/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "storybook": "^10.4.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.0.0"
  }
}
